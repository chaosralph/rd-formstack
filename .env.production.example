APP_ENV=production
APP_DEBUG=false
APP_BASE_URL=https://rddigital.de
APP_TRUSTED_HOSTS=rddigital.de,www.rddigital.de
CSP_REPORT_ONLY=false
ENABLE_HSTS=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
RATE_LIMIT_FAIL_MODE=closed

DB_HOST=rddigital-db
DB_PORT=3306
DB_NAME=rd_formstack
DB_USER=rd_user
DB_PASS=change_me
DB_CHARSET=utf8mb4
DB_ROOT_PASSWORD=change_me_root

MAIL_FROM_ADDRESS=info@rddigital.de
MAIL_FROM_NAME=RD Formstack Solutions
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USERNAME=info@example.com
SMTP_PASSWORD=change_me

IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_ENCRYPTION=ssl
IMAP_VALIDATE_CERT=true
IMAP_USERNAME=leads@example.com
IMAP_PASSWORD=change_me
IMAP_MAILBOX=INBOX
IMAP_SYNC_LIMIT=25
