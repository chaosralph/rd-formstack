# DMS .htaccess

# Verzeichnislisting deaktivieren
Options -Indexes

# Erlaube Kamera fuer diese App-Origin (wichtig fuer mobile Browser wie Samsung/Chrome)
<IfModule mod_headers.c>
    Header always unset Permissions-Policy
    Header always set Permissions-Policy "camera=(self), microphone=(), geolocation=()"
</IfModule>

# PHP-Einstellungen (falls erlaubt)
<IfModule mod_php.c>
    php_value upload_max_filesize 25M
    php_value post_max_size 50M
    php_value max_execution_time 120
    php_value memory_limit 128M
</IfModule>

# Schütze sensible Dateien
<FilesMatch "\.(sql|md|json|lock)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Schütze includes-Verzeichnis
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^templates/ - [F,L]
</IfModule>

# Caching für statische Assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
</IfModule>

# GZIP-Komprimierung
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
